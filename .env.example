GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URL=http://localhost:8080/auth/youtube/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URL=http://localhost:8080/auth/instagram/callback

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# TikTok Login Kit for web requires an absolute HTTPS redirect URI.
TIKTOK_REDIRECT_URL=https://counter.yourdomain.com/auth/tiktok/callback

# Optional server binding overrides.
PORT=8080
# APP_ADDR=:8080
APP_DOMAIN=counter.yourdomain.com
PUBLIC_BASE_URL=https://counter.yourdomain.com
# Optional: if set, the root URL / redirects to /board/<slug> for public visitors.
# The creator dashboard remains available at /dashboard.
# PUBLIC_ROOT_BOARD_SLUG=board-abc123xy

# Optional: put session persistence on a mounted disk in production.
SESSION_STORE_PATH=data/sessions.json
# Optional: keep published public boards on a mounted disk too.
BOARD_STORE_PATH=data/boards.json
# Recommended for production: base64-encoded 32-byte key, for example:
# openssl rand -base64 32
SESSION_ENCRYPTION_KEY=

# Legacy single-channel prototype values used by the old websocket endpoint.
YOUTUBE_KEY=
CHANNEL_ID=
